generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  VIEWER
}

enum ContractType {
  MAINTENANCE
  SUPPORT
  SERVICE
  LICENSING
}

enum ContractStatus {
  ACTIVE
  EXPIRING_SOON
  OVERDUE
  RENEWED
  DECLINED
  CANCELLED
  ON_HOLD
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model AppUser {
  id      String   @id @default(cuid())
  clerkId String   @unique
  name    String?
  email   String   @unique
  role    UserRole @default(STAFF)

  assignedContracts Contract[]     @relation("AssignedContracts")
  notes             InternalNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id            String  @id @default(cuid())
  companyName   String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  status        String  @default("Active")

  contracts Contract[]
  contacts  Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id          String  @id @default(cuid())
  name        String
  company     String
  role        String?
  email       String?
  phone       String?
  status      String  @default("Active")
  lastContact String?
  notes       String?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contract {
  id           String         @id @default(cuid())
  contractName String
  contractType ContractType
  status       ContractStatus @default(ACTIVE)

  reference          String?
  serviceDescription String?
  startDate          DateTime
  renewalDate        DateTime
  contractValue      Float?
  currency           String   @default("MUR")
  autoRenewal        Boolean  @default(false)
  renewalFrequency   String   @default("Yearly")
  noticePeriod       String?
  assignedTo         String?
  recipientTypes     String[] @default([])

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  assignedStaffId String?
  assignedStaff   AppUser? @relation("AssignedContracts", fields: [assignedStaffId], references: [id])

  reminders RenewalReminder[]
  emailLogs EmailLog[]
  notes     InternalNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RenewalReminder {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  daysBefore Int
  sent       Boolean   @default(false)
  sentAt     DateTime?

  createdAt DateTime @default(now())
}

model EmailTemplate {
  id        String  @id @default(cuid())
  name      String
  subject   String
  body      String
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  recipient     String
  subject       String
  reminderStage String?
  status        EmailStatus @default(PENDING)
  errorMessage  String?
  sentAt        DateTime?

  createdAt DateTime @default(now())
}

model InternalNote {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  authorId String?
  author   AppUser? @relation(fields: [authorId], references: [id])

  note String

  createdAt DateTime @default(now())
}
